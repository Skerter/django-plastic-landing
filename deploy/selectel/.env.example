# ════════════════════════════════════════════════════════════════════════════
# Окружение онлайн-демо за Traefik (тестовый сервер «assa»).
# На сервере: cp .env.example .env  и заполнить SECRET_KEY + пароль БД.
# .env НЕ коммитить.
# ════════════════════════════════════════════════════════════════════════════

# --- Хост демо (читает и compose-роутеры Traefik, и Django ниже) ---
# Поддомен на nip.io резолвится в указанный IP без DNS-настроек.
DEMO_HOST=demo.135.106.161.48.nip.io

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.prod
SECRET_KEY=generate-a-50-char-random-secret
DEBUG=False
ALLOWED_HOSTS=demo.135.106.161.48.nip.io
# За HTTPS-прокси Django 5 требует доверенный origin для CSRF на POST-формах.
CSRF_TRUSTED_ORIGINS=https://demo.135.106.161.48.nip.io

# --- Демо-режим: внешние интеграции не вызываются, qcluster не нужен ---
DEMO_MODE=True

# --- База данных (хост = имя сервиса db) ---
DATABASE_URL=postgres://demoplast:change-me-strong-password@db:5432/demoplast
POSTGRES_DB=demoplast
POSTGRES_USER=demoplast
POSTGRES_PASSWORD=change-me-strong-password

# --- Sentry (опционально) ---
SENTRY_DSN=

# --- Ниже всё пустое: при DEMO_MODE=True не используется, но prod.py читает env ---
DEFAULT_FROM_EMAIL=noreply@demo.example
EMAIL_HOST=
EMAIL_PORT=465
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False
TELEGRAM_BOT_TOKEN=
AMOCRM_BASE_URL=
AMOCRM_CLIENT_ID=0
AMOCRM_CLIENT_SECRET=
AMOCRM_REDIRECT_URI=
AMOCRM_PIPELINE_ID=0
AMOCRM_STATUS_ID=0
