# ════════════════════════════════════════════════════════════════════════════
# Шаблон прод-окружения. На сервере скопировать в .env и заполнить реальными
# значениями. НЕ коммитить заполненный файл — .env в .gitignore.
# ════════════════════════════════════════════════════════════════════════════

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.prod
SECRET_KEY=generate-a-50-char-random-secret
DEBUG=False
ALLOWED_HOSTS=demoplast.example

# --- Демо-режим ---
# В реальном проде — False (внешние интеграции включены). True оставляют только
# для публичного демо без настоящих ключей CRM/Telegram/SMTP.
DEMO_MODE=False

# --- База данных ---
# Хост = имя сервиса в compose (db), НЕ localhost.
# Пользователь/пароль/имя БД должны совпадать с POSTGRES_* ниже.
DATABASE_URL=postgres://demoplast:change-me-strong-password@db:5432/demoplast

# --- Postgres (читает контейнер db через ${...} в compose.prod.yaml) ---
POSTGRES_DB=demoplast
POSTGRES_USER=demoplast
POSTGRES_PASSWORD=change-me-strong-password

# --- Sentry ---
SENTRY_DSN=

# --- Email (SMTP) ---
# Порт 465 + SSL (implicit). USER и FROM обычно совпадают.
# EMAIL_HOST_PASSWORD — пароль приложения провайдера, НЕ обычный пароль.
# Получатель уведомлений — в админке (SiteSettings.email_notifications), НЕ здесь.
DEFAULT_FROM_EMAIL=noreply@demoplast.example
EMAIL_HOST=smtp.example.com
EMAIL_PORT=465
EMAIL_HOST_USER=noreply@demoplast.example
EMAIL_HOST_PASSWORD=
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False

# --- Telegram ---
TELEGRAM_BOT_TOKEN=

# --- amoCRM ---
AMOCRM_BASE_URL=https://your-account.amocrm.ru
AMOCRM_CLIENT_ID=
AMOCRM_CLIENT_SECRET=
AMOCRM_REDIRECT_URI=https://demoplast.example/amocrm/callback/
AMOCRM_PIPELINE_ID=
AMOCRM_STATUS_ID=

# --- Certbot / домен (читает init-letsencrypt.sh, НЕ Django) ---
DOMAIN=demoplast.example
CERTBOT_EMAIL=admin@demoplast.example
