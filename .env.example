# ════════════════════════════════════════════════════════════════════════════
# Шаблон dev-окружения. Скопировать в .env: `cp .env.example .env`.
# Все значения — плейсхолдеры. .env в .gitignore, в репо только этот шаблон.
# ════════════════════════════════════════════════════════════════════════════

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.docker
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- База данных ---
# Хост `db` — имя сервиса в docker compose. Совпадает с POSTGRES_* в compose.yaml.
DATABASE_URL=postgres://demoplast:demoplast@db:5432/demoplast

# --- Демо-режим ---
# DEMO_MODE=True отключает реальные внешние вызовы (email-SMTP, Telegram, amoCRM):
# заявка сохраняется в БД, каналы только логируют «demo, skipped». Так демо
# поднимается без единого реального ключа. Для боевого режима — False.
DEMO_MODE=True

# --- Sentry (прод) ---
SENTRY_DSN=

# --- Email ---
# Технический ящик-отправитель. USER и FROM обычно совпадают (часть провайдеров
# не даёт слать от чужого имени). Получатель уведомлений — в админке
# (SiteSettings.email_notifications), НЕ здесь.
# В dev письма печатаются в консоль (EMAIL_BACKEND в dev.py); при DEMO_MODE=True
# отправка вообще не вызывается.
DEFAULT_FROM_EMAIL=noreply@demoplast.example
EMAIL_HOST=smtp.example.com
EMAIL_PORT=465
EMAIL_HOST_USER=noreply@demoplast.example
EMAIL_HOST_PASSWORD=change-me-app-password
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False

# --- Telegram ---
# Токен бота для уведомлений о заявках. chat_id задаётся в админке (SiteSettings).
TELEGRAM_BOT_TOKEN=

# --- amoCRM ---
# BASE_URL: https://<поддомен>.amocrm.ru. CLIENT_*/REDIRECT_URI — из карточки интеграции.
# PIPELINE/STATUS — опционально (пусто = первый этап главной воронки).
# Первая пара токенов получается командой: manage.py amocrm_auth <code>
AMOCRM_BASE_URL=https://your-account.amocrm.ru
AMOCRM_CLIENT_ID=
AMOCRM_CLIENT_SECRET=
AMOCRM_REDIRECT_URI=https://demoplast.example/amocrm/callback/
AMOCRM_PIPELINE_ID=0
AMOCRM_STATUS_ID=0
